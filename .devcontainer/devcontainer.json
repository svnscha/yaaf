{
    "name": "yaaf Linux musl",
    "build": {
        "context": "..",
        "dockerfile": "Dockerfile"
    },
    "remoteUser": "vscode",
    "containerEnv": {
        "CC": "clang",
        "CMAKE_TOOLCHAIN_FILE": "${containerWorkspaceFolder}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CXX": "clang++",
        "VCPKG_OVERLAY_TRIPLETS": "${containerWorkspaceFolder}/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-linux-musl-static",
        "VCPKG_ROOT": "${containerWorkspaceFolder}/vcpkg"
    },
    "postCreateCommand": "bash ./.devcontainer/setup-vcpkg.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-python.python",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools",
                "twxs.cmake"
            ],
            "settings": {
                "cmake.buildDirectory": "${workspaceFolder}/build/linux-musl-static",
                "cmake.configurePreset": "linux-musl-static",
                "cmake.configureEnvironment": {
                    "CC": "clang",
                    "CMAKE_TOOLCHAIN_FILE": "${workspaceFolder}/vcpkg/scripts/buildsystems/vcpkg.cmake",
                    "CXX": "clang++",
                    "VCPKG_OVERLAY_TRIPLETS": "${workspaceFolder}/triplets",
                    "VCPKG_TARGET_TRIPLET": "x64-linux-musl-static",
                    "VCPKG_ROOT": "${workspaceFolder}/vcpkg"
                },
                "cmake.configureOnOpen": true,
                "cmake.generator": "Ninja",
                "cmake.useCMakePresets": "always"
            }
        }
    }
}